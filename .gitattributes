# Auto-detect text files and normalize line endings
* text=auto

# Python
*.py text diff=python
*.pyi text diff=python

# Rust
*.rs text diff=rust
Cargo.toml text
Cargo.lock text -diff

# Config
*.toml text
*.yaml text
*.yml text
*.json text
*.md text
*.env text

# Binary / generated
*.whl binary
*.pyc binary
