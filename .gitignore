# Secrets / local config
.env*
!.env.example

# OS / editor noise
.DS_Store

# Merge / backup leftovers
*.orig
*.rej
*.bak

# Python
__pycache__/
*.pyc
*.pyo

# Binaries fetched by `ImportLidarrManual.py --setup` (e.g. rsgain)
/tools/lidarr/bin/

# scripts/clean-broken-albums.sh input: user-specific album paths; not committed
/broken.txt
/scripts/broken.txt

# Rust
smpr/target/
rabsody/target/

# Rust coverage artifacts (produced locally by the patch-coverage gate)
*.profraw
lcov.info
cobertura.xml
tarpaulin-report.*

# Reports
*.csv

# SQLite databases (smpr authoritative-source store + WAL/SHM sidecars)
*.db
*.db-wal
*.db-shm
*.sqlite
*.sqlite3

# IDE
.vscode/
.idea/

# Claude Code
.claude/*
!.claude/release.toml
.serena/

# AI-generated process docs (specs, plans)
docs/superpowers/

# Git worktrees
.worktrees/

# Transient session checkpoint (resume state; never committed)
SESSION-STATE.md

# Local design ideation / someday-maybe notes (never committed)
*.local.md

# Playwright MCP browser session artifacts
.playwright-mcp/
